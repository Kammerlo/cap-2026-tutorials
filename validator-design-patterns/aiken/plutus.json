    "oracle/ConsumerDatum": {
      "title": "ConsumerDatum",
      "description": "A toy \"buy\" validator that authorises a spend only if the oracle price is\n above a configured threshold AND the oracle reading is fresh enough.\n\n The consumer NEVER spends the oracle UTXO — it only references it. This is\n what makes the oracle pattern scale: thousands of consumer transactions in\n the same block can all reference the same oracle UTXO concurrently.",
      "anyOf": [
        {
          "title": "ConsumerDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "threshold",
              "description": "Minimum acceptable price.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "max_age_ms",
              "description": "Reading must be no older than this (in ms) at the time of validation.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "owner",
              "description": "Address that owns this consumer UTXO.",
              "$ref": "#/definitions/aiken~1crypto~1VerificationKeyHash"
            }
          ]
        }
      ]
    },
